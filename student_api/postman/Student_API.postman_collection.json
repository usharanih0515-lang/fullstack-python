  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/register/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"student1\",\n  \"email\": \"student1@example.com\",\n  \"first_name\": \"Alice\",\n  \"last_name\": \"Smith\",\n  \"password\": \"TestPass123!\",\n  \"password_confirm\": \"TestPass123!\",\n  \"role\": \"student\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "pm.test('Has user data', () => { const j = pm.response.json(); pm.expect(j).to.have.property('user'); });" ]}}]
        },
        {
          "name": "Login (saves tokens)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/login/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"TestPass123!\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const j = pm.response.json();", "if (j.access) { pm.collectionVariables.set('access_token', j.access); pm.collectionVariables.set('refresh_token', j.refresh); console.log('Tokens saved'); }"]}}]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/refresh/",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "const j = pm.response.json();", "if (j.access) { pm.collectionVariables.set('access_token', j.access); pm.collectionVariables.set('refresh_token', j.refresh); }"]}}]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/logout/",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Logged out', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/profile/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has role', () => { const j = pm.response.json(); pm.expect(j).to.have.property('role'); });"]}}]
        },
        {
          "name": "Update Profile (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/auth/profile/",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"bio\": \"Computer Science student, Year 2\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/change-password/",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"old_password\": \"TestPass123!\",\n  \"new_password\": \"NewPass456!\",\n  \"new_password_confirm\": \"NewPass456!\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "List Users (Admin only)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/users/",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}]
          },
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Admin or 403', () => { pm.expect([200, 403]).to.include(pm.response.code); });"]}}]
        }
      ]
    },
